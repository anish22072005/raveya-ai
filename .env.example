# AI Provider: "groq" (free) or "openai"
AI_PROVIDER=groq

# Groq (free) — https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (paid, optional)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Database
DATABASE_URL=sqlite+aiosqlite:///./raveya.db

# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=raveya

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# WhatsApp Escalation
ESCALATION_PHONE=whatsapp:+1234567890
